{
  "name": "epm",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2.8.0",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "passport": "^0.7.0"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.49"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds-watch",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "undeploy": "cf undeploy epm --delete-services --delete-service-keys --delete-service-brokers",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "cds": {
    "requires": {
      "db": {
        "kind": "hana",
        "[development]": {
          "kind": "sqlite",
          "credentials": {
            "url": "db.sqlite"
          }
        }
      },
      "auth": {
        "kind": "xsuaa",
        "[development]": {
          "kind": "mocked",
          "users": {
            "*": false,
            "alice": {
              "password": "alice",
              "roles": [
                "PurchaseManager",
                "Viewer"
              ],
              "attr": {
                "Department": "Engineering"
              }
            },
            "bob": {
              "password": "bob",
              "roles": [
                "PurchaseManager",
                "Viewer"
              ],
              "attr": {
                "Department": "Marketing"
              }
            },
            "carol": {
              "password": "carol",
              "roles": [
                "Viewer"
              ]
            },
            "dave": {
              "password": "dave",
              "roles": [
                "Administrator",
                "PurchaseManager",
                "Viewer"
              ]
            }
          }
        }
      }
    }
  }
}
